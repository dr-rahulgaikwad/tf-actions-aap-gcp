# Terraform Variables — copy to terraform.tfvars and fill in your values
# Note: Most variables are auto-set by the bootstrap module in HCP Terraform workspace.
#       Only the ones marked "set manually" need your attention.

# Vault
vault_addr        = "https://your-vault.vault.hashicorp.cloud:8200"
vault_namespace   = "admin"
vault_gcp_roleset = "terraform-provisioner"

# GCP
gcp_project_id = "your-project-id"
gcp_region     = "us-central1"
gcp_zone       = "us-central1-a"

# VMs
vm_count        = 2
vm_machine_type = "e2-medium"
ubuntu_image    = "projects/ubuntu-os-cloud/global/images/ubuntu-2004-focal-v20231101"

# AAP
aap_hostname        = "https://your-aap-server.example.com"
aap_oidc_issuer_url = "https://your-aap-server.example.com"
aap_oidc_repository = "your-org/tf-actions-aap-gcp"
aap_job_template_id = 0 # Set after creating job template in AAP (Step 4.4)

# SSH
ansible_user = "ubuntu"

# Vault SSH CA public key — from: cd bootstrap && terraform output -raw vault_ssh_ca_public_key
vault_ssh_ca_public_key = "ssh-rsa AAAA..."

# Environment
environment = "demo" # demo | dev | staging | production

# Security
aap_server_ip           = ""    # Required for production: set to AAP server IP
aap_insecure_skip_verify = true  # Set false in production (requires valid TLS cert on AAP)
