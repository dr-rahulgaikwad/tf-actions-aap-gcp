# Terraform Variables Configuration
# Copy this file to terraform.tfvars and fill in your values

# Vault Configuration
vault_addr              = "https://your-vault.vault.hashicorp.cloud:8200"
vault_namespace         = "admin"
vault_gcp_roleset       = "terraform-provisioner"

# GCP Configuration
gcp_project_id          = "your-project-id"
gcp_region              = "us-central1"
gcp_zone                = "us-central1-a"

# VM Configuration
vm_count                = 2
vm_machine_type         = "e2-medium"
ubuntu_image            = "ubuntu-os-cloud/ubuntu-2004-lts"

# AAP Configuration
aap_hostname            = "https://your-aap-server.example.com"
aap_oidc_issuer_url     = "https://your-aap-server.example.com"
aap_oidc_repository     = "your-org/your-repo"
aap_job_template_id     = 14  # Update after creating job template in AAP

# SSH Configuration (from OS Login)
ansible_user            = "rahul_gaikwad_hashicorp_com"  # Get from: gcloud compute os-login describe-profile --format='value(posixAccounts[0].username)'

# Environment Configuration
environment             = "demo"  # Options: demo, dev, staging, production
managed_by              = "terraform"

# Security Configuration (required for production)
aap_server_ip           = ""  # Set to AAP server IP for production (e.g., "1.2.3.4")

# Optional: Advanced Configuration
enable_os_login         = true
enable_cloud_logging    = true
enable_cloud_monitoring = true