{
  "INPUT_CONFIGURATION": {
    "fields": [
      {
        "id": "vault_addr",
        "label": "Vault Address",
        "type": "string",
        "help_text": "Vault server address (e.g., https://vault.example.com:8200)"
      },
      {
        "id": "vault_namespace",
        "label": "Vault Namespace",
        "type": "string",
        "default": "admin",
        "help_text": "Vault namespace (default: admin)"
      },
      {
        "id": "role_id",
        "label": "AppRole Role ID",
        "type": "string",
        "secret": true,
        "help_text": "Vault AppRole Role ID"
      },
      {
        "id": "secret_id",
        "label": "AppRole Secret ID",
        "type": "string",
        "secret": true,
        "help_text": "Vault AppRole Secret ID"
      },
      {
        "id": "ssh_role",
        "label": "SSH Role Name",
        "type": "string",
        "default": "aap-ssh",
        "help_text": "Vault SSH role name (default: aap-ssh)"
      },
      {
        "id": "ssh_user",
        "label": "SSH Username",
        "type": "string",
        "help_text": "GCP OS Login username"
      }
    ],
    "required": ["vault_addr", "role_id", "secret_id", "ssh_user"]
  },
  "INJECTOR_CONFIGURATION_YAML": "env:\n  VAULT_ADDR: '{{ vault_addr }}'\n  VAULT_NAMESPACE: '{{ vault_namespace }}'\n  VAULT_ROLE_ID: '{{ role_id }}'\n  VAULT_SECRET_ID: '{{ secret_id }}'\n  VAULT_SSH_ROLE: '{{ ssh_role }}'\nextra_vars:\n  ansible_user: '{{ ssh_user }}'\n  vault_ssh_user: '{{ ssh_user }}'\n"
}
