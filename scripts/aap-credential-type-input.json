{
  "fields": [
    {
      "id": "vault_addr",
      "label": "Vault Address",
      "type": "string",
      "help_text": "Vault server address (e.g., https://vault.hashicorp.cloud:8200)"
    },
    {
      "id": "vault_namespace",
      "label": "Vault Namespace",
      "type": "string",
      "default": "admin",
      "help_text": "Vault namespace (for HCP Vault, typically 'admin')"
    },
    {
      "id": "vault_role_id",
      "label": "AppRole Role ID",
      "type": "string",
      "secret": true,
      "help_text": "Vault AppRole Role ID for authentication"
    },
    {
      "id": "vault_secret_id",
      "label": "AppRole Secret ID",
      "type": "string",
      "secret": true,
      "help_text": "Vault AppRole Secret ID for authentication"
    },
    {
      "id": "vault_ssh_role",
      "label": "Vault SSH Role",
      "type": "string",
      "default": "aap-oslogin",
      "help_text": "Vault SSH role name for signing certificates"
    },
    {
      "id": "ssh_username",
      "label": "SSH Username",
      "type": "string",
      "help_text": "OS Login username (e.g., your_email_domain_com)"
    },
    {
      "id": "ssh_public_key",
      "label": "SSH Public Key",
      "type": "string",
      "multiline": true,
      "help_text": "SSH public key to be signed by Vault (contents of ~/.ssh/id_rsa.pub)"
    }
  ],
  "required": [
    "vault_addr",
    "vault_role_id",
    "vault_secret_id",
    "ssh_username",
    "ssh_public_key"
  ]
}
